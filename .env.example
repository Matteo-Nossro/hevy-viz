# PostgreSQL
POSTGRES_USER=hevy
POSTGRES_PASSWORD=changeme_strong_password
POSTGRES_DB=hevy_viz

# PostgREST — mot de passe du rôle authenticator
# Attention : modifiable uniquement avant le premier docker compose up.
# Après, ALTER ROLE via Adminer ou docker compose down -v (perd les données).
PGRST_AUTHENTICATOR_PASSWORD=changeme_authenticator_password

# Ports exposés sur le LXC (à pointer depuis le nginx Proxmox)
HTTP_PORT=8080
ADMINER_PORT=8081
